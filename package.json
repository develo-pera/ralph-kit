{
  "name": "@develo-pera/ralph-kit",
  "version": "0.1.4",
  "description": "Conversational questionnaire + local Kanban dashboard for Ralph Loop projects",
  "bin": {
    "ralph-kit": "./dist/bin/ralph-kit.js"
  },
  "type": "commonjs",
  "main": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib/index.d.ts",
      "require": "./dist/lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "board": "tsx src/bin/ralph-kit.ts board",
    "dev": "concurrently -n api,web -c blue,green \"tsx src/bin/ralph-kit.ts board --dir ${RALPH_KIT_DEV_DIR:-fixtures/demo}\" \"vite --config web/vite.config.ts\"",
    "build": "tsc -p tsconfig.json && vite build --config web/vite.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepare": "npm run build",
    "prepublishOnly": "npm test && npm run build"
  },
  "files": [
    "dist",
    "web/dist",
    "commands",
    "README.md"
  ],
  "dependencies": {
    "chalk": "^4.1.2",
    "chokidar": "^3.6.0",
    "commander": "^12.1.0",
    "express": "^4.19.2",
    "prompts": "^2.4.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "@types/node": "^25.6.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/develo-pera/ralph-kit.git"
  },
  "license": "MIT"
}
